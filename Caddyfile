{
	email {$LETSENCRYPT_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	# API + admin Django → backend gunicorn
	@backend path /api/* /admin/* /static/* /static-djangoadmin/*
	handle @backend {
		reverse_proxy backend:8000 {
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-For {remote_host}
		}
	}

	# Tout le reste → SPA React via nginx
	handle {
		reverse_proxy frontend:80
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "same-origin"
		X-Frame-Options "DENY"
		# CSP : restreint à 'self' pour script/style. Tailwind/React injectent
		# du CSS inline → 'unsafe-inline' requis pour style-src.
		# Pas de CDN externe utilisé → tout en self.
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://tile.openstreetmap.org; connect-src 'self' https://*.openrouteservice.org; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		Permissions-Policy "geolocation=(self), camera=(self), microphone=()"
	}
}
