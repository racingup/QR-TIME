# ─────────────────────────────────────────────────────────────────────
# Production environment — copy to .env.production on the VPS, fill in,
# and NEVER commit the filled file.
# ─────────────────────────────────────────────────────────────────────

# Domain (must point to this VPS via DNS A record).
DOMAIN=qrtime.ch

# Email used by Caddy for Let's Encrypt account.
LETSENCRYPT_EMAIL=ops@qrtime.ch

# Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# Postgres credentials (free choice, will be created on first boot).
POSTGRES_DB=qrtime
POSTGRES_USER=qrtime
POSTGRES_PASSWORD=REPLACE_ME_WITH_A_STRONG_PASSWORD

# First-deploy bootstrap — superuser is created ONLY if no superuser exists.
# After the first successful deploy, you can blank these out.
INITIAL_SUPERUSER_USERNAME=admin
INITIAL_SUPERUSER_PASSWORD=REPLACE_ME_WITH_A_STRONG_PASSWORD
INITIAL_SUPERUSER_EMAIL=admin@qrtime.ch

# ── SMTP (rappels d'oubli de pointage, notifications) ──────────────────
# Si non rempli : les mails ne partent pas (loggé en WARNING, pas d'erreur).
# Pour Infomaniak : EMAIL_HOST=mail.infomaniak.com  EMAIL_PORT=587  EMAIL_USE_TLS=1
EMAIL_HOST=mail.infomaniak.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@qrtime.ch
EMAIL_HOST_PASSWORD=REPLACE_ME_WITH_SMTP_PASSWORD
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=qrtime.ch <no-reply@qrtime.ch>

# ── Politique de rétention LPD ─────────────────────────────────────────
# Sessions, missions, absences, alertes purgées après N années.
# Audit log (Art. 958f CO) conservé plus longtemps.
RETENTION_TIME_DATA_YEARS=5
RETENTION_AUDIT_LOG_YEARS=10

# ── Backup PostgreSQL ──────────────────────────────────────────────────
# Nombre de jours conservés dans le volume `pgbackups` (le service db-backup
# fait un dump à 02:30 UTC chaque nuit). Voir ops/README.md.
BACKUP_RETENTION_DAYS=30

# ── Routing — calcul du temps de trajet voiture (Art. 13 al. 3 OLT 1) ──
# Service externe : OpenRouteService — free tier 2000 requêtes/jour.
# Compte gratuit : https://openrouteservice.org/dev/#/signup
# Sans clé : les calculs de trajet renvoient None silencieusement (l'admin
# saisit alors manuellement les minutes de trajet standard pour chaque
# collaborateur, et le calcul de mission se fait sans bonus de trajet).
ROUTING_BACKEND=ors
ORS_API_KEY=REPLACE_ME_WITH_YOUR_ORS_API_KEY
