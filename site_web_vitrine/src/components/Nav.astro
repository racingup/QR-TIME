---
---
<header class="sticky top-0 z-50 px-4 pt-4">
  <nav class="glass-strong max-w-6xl mx-auto rounded-full px-5 sm:px-6 py-3 flex items-center justify-between">
    <a href="#top" class="flex items-center gap-2.5 font-semibold tracking-tight">
      <img src="/logo.png" alt="qrtime.ch" class="h-8 w-auto" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';" />
      <span class="hidden items-center justify-center w-8 h-8 rounded-xl bg-brand text-white">
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="3" height="3"/><rect x="18" y="14" width="3" height="3"/><rect x="14" y="18" width="3" height="3"/><rect x="18" y="18" width="3" height="3"/></svg>
      </span>
      <span class="text-[1.05rem]">qrtime<span class="text-brand">.ch</span></span>
    </a>
    <div class="hidden md:flex items-center gap-7 text-sm text-ink-700">
      <a href="#fonctionnalites" class="hover:text-ink-900 transition">Fonctionnalités</a>
      <a href="#usages" class="hover:text-ink-900 transition">Cas d'usage</a>
      <a href="#tarifs" class="hover:text-ink-900 transition">Tarifs</a>
      <a href="#securite" class="hover:text-ink-900 transition">Sécurité</a>
      <a href="#faq" class="hover:text-ink-900 transition">FAQ</a>
    </div>
    <div class="flex items-center gap-2">
      <a href="#contact" class="btn-primary text-sm px-4 py-2">Demander une démo</a>
    </div>
  </nav>
</header>
